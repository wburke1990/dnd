<Panel>
    <InputField
        id="TitleId"
        width="2800"
        height="280"
        rotation="0 0 180"
        position="7 -135 -40"
        interactable="False"
        fontSize="180"
        fontStyle="Bold"
        caretWidth  ="10"
        characterLimit="1012"
        colors="rgba(1,1,1,0)|#FFFFFFBB|#C8C8C8|rgba(0.78,0.78,0.78,0)"
        lineType="multiLineNewLine"
        navigation="None"
        textColor="#6b251b"
        textAlignment="TopLeft"
        scale="0.06 0.1 0.1"

        onEndEdit="titleEndEdit"/>

    <InputField
        id="InputId"
        width="10"
        height="10"
        rotation="0 0 180"
        position="220 0 -40"
        interactable="False"
        fontSize="150"
        caretWidth  ="10"
        colors="#FFFFFFAA|#FFFFFFBB|#C8C8C8|rgba(0.78,0.78,0.78,0)"
        lineType="multiLineNewLine"
        navigation="None"
        textColor="Black"
        textAlignment="TopLeft"
        scale="0.06 0.1 0.1"

        onValueChanged="onInputChanged"
        onEndEdit="fieldEndEdit"/>

    <Text
        id="InputTextId"
        alignment="UpperLeft"
        position="0 30 -40"
        color="Black"
        font="DND-Font/Tts_dnd_icons-Regular"
        fontStyle="Bold"
        width="3300"
        height="3000"
        fontSize = "150"
        rotation="180 180 0"
        scale="0.06 0.1 0.1"/>

    <ToggleButton
        id="LockId"
        Width="600"
        Height="200"
        position="-84 135 -40"
        rotation="0 0 180"
        text="Reload"
        color="rgba{0,0.6, 0.8, 100}"
        fontSize="125"
        fontStyle="bold"
        textColor= "White"
        textShadow="Black"
        scale="0.06 0.1 0.1"
        
        interactable="true"
        onValueChanged="LockUnlock"/>
</Panel>
